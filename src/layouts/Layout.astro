---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'ラーメン、それから。', description = 'ラーメンを食べて、考えて、また食べる。東京在住・麺狂い女子のブログ。' } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
        background: #fffdf8;
        color: #2c2c2c;
        line-height: 1.8;
      }
      header {
        background: #c0392b;
        padding: 12px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
      }
      header a { text-decoration: none; }
      header .site-title {
        color: #fff;
        font-size: 1.2rem;
        font-weight: bold;
        letter-spacing: 0.05em;
        white-space: nowrap;
      }
      header .site-title span {
        display: none;
      }
      nav {
        display: flex;
        gap: 4px;
        flex-shrink: 0;
      }
      nav a {
        color: #fff;
        text-decoration: none;
        padding: 6px 10px;
        font-size: 0.85rem;
        opacity: 0.9;
        white-space: nowrap;
      }
      nav a:hover { opacity: 1; text-decoration: underline; }
      @media (min-width: 600px) {
        header .site-title { font-size: 1.4rem; }
        header .site-title span { display: inline; font-size: 0.9rem; font-weight: normal; margin-left: 8px; opacity: 0.85; }
        nav a { margin-left: 8px; font-size: 0.9rem; }
      }
      main {
        max-width: 860px;
        margin: 40px auto;
        padding: 0 20px;
      }
      footer {
        text-align: center;
        padding: 40px 20px;
        color: #999;
        font-size: 0.85rem;
        border-top: 1px solid #eee;
        margin-top: 60px;
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/" class="site-title">🍜 ラーメン、それから。<span>— 食べて、考えて、また食べる。</span></a>
      <nav>
        <a href="/">ホーム</a>
        <a href="/blog">記事一覧</a>
        <a href="/about">このブログについて</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2026 ラーメン、それから。</p>
    </footer>
  </body>
</html>
