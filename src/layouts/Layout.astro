---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'ラーメン、それから。', description = 'ラーメンがモンブランにしか見えないOLのブログ。食べて、考えて、また食べる。' } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500&family=Shippori+Mincho:wght@500;600&display=swap" rel="stylesheet">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Noto Sans JP', 'Hiragino Sans', sans-serif;
        background: #fdf8f3;
        color: #2a2a2a;
        line-height: 1.9;
      }
      header {
        background: #fff;
        border-bottom: 1px solid #f0e8e4;
        padding: 0 24px;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .header-inner {
        max-width: 960px;
        margin: 0 auto;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }
      header a { text-decoration: none; }
      .site-title {
        font-family: 'Shippori Mincho', serif;
        font-weight: 600;
        font-size: 1.1rem;
        color: #b5352a;
        white-space: nowrap;
        flex-shrink: 0;
        letter-spacing: 0.04em;
      }
      nav { display: flex; }
      nav a {
        color: #888;
        text-decoration: none;
        padding: 6px 10px;
        font-size: 0.82rem;
        font-weight: 500;
        border-radius: 20px;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
      }
      nav a:hover { background: #fdf0ed; color: #b5352a; }
      main {
        max-width: 960px;
        margin: 48px auto;
        padding: 0 20px;
      }
      footer {
        text-align: center;
        padding: 40px 20px;
        color: #ccc;
        font-size: 0.78rem;
        border-top: 1px solid #f0e8e4;
        margin-top: 80px;
        letter-spacing: 0.05em;
      }
      @media (max-width: 600px) {
        .header-inner { height: auto; padding: 10px 0; flex-wrap: wrap; gap: 8px; }
        nav a { padding: 4px 8px; font-size: 0.78rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="site-title">🍜 ラーメン、それから。</a>
        <nav>
          <a href="/">ホーム</a>
          <a href="/blog">記事一覧</a>
          <a href="/about">このブログについて</a>
          <a href="/contact">お問い合わせ</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2026 ラーメン、それから。</p>
    </footer>
  </body>
</html>
