---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title="ラーメン、それから。">
  <section class="hero">
    <p class="hero-label">食べて、考えて、また食べる。</p>
    <h1>ラーメン、それから。</h1>
    <p class="hero-sub">ラーメンがモンブランにしか見えないOLが、<br>食べたものを忘れたくなくて書いています。</p>
    <a href="/blog" class="btn">記事一覧を見る</a>
  </section>

  <section class="recent">
    <div class="section-header">
      <h2>最新記事</h2>
      <a href="/blog" class="see-all">すべて見る →</a>
    </div>
    <div class="card-grid">
      {recentPosts.map(post => (
        <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-card">
          <div class="card-thumb">
            {post.data.image
              ? <img src={post.data.image} alt={post.data.title} />
              : <div class="card-emoji">{post.data.emoji}</div>
            }
          </div>
          <div class="card-body">
            <time>{post.data.pubDate.toLocaleDateString('ja-JP')}</time>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    text-align: center;
    padding: 72px 24px 64px;
    margin-bottom: 64px;
  }
  .hero-label {
    font-size: 0.8rem;
    color: #b5352a;
    letter-spacing: 0.15em;
    margin-bottom: 16px;
    font-weight: 500;
  }
  .hero h1 {
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: 0.08em;
    margin-bottom: 20px;
    line-height: 1.3;
  }
  .hero-sub {
    font-size: 0.95rem;
    color: #666;
    line-height: 2;
    margin-bottom: 36px;
  }
  .btn {
    display: inline-block;
    background: #b5352a;
    color: #fff;
    padding: 12px 32px;
    border-radius: 30px;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: background 0.2s, transform 0.15s;
  }
  .btn:hover { background: #9b2d22; transform: translateY(-1px); }

  /* ── Recent posts ── */
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }
  .section-header h2 {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: 0.04em;
  }
  .see-all {
    font-size: 0.8rem;
    color: #b5352a;
    text-decoration: none;
    font-weight: 500;
  }
  .see-all:hover { text-decoration: underline; }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }
  .post-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid #f0e8e4;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.07);
  }
  .card-thumb {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #fdf0ed;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card-emoji { font-size: 3rem; }
  .card-body { padding: 16px 20px 20px; }
  .card-body time {
    font-size: 0.75rem;
    color: #bbb;
    letter-spacing: 0.03em;
  }
  .card-body h3 {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.05rem;
    font-weight: 600;
    margin: 6px 0 8px;
    color: #2a2a2a;
    line-height: 1.5;
  }
  .card-body p {
    font-size: 0.82rem;
    color: #999;
    line-height: 1.6;
  }
</style>
