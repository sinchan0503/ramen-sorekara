---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | ラーメン、それから。`} description={post.data.description}>
  <article class="post">
    <header class="post-header">
      <time>{post.data.pubDate.toLocaleDateString('ja-JP')}</time>
      <h1>{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
    </header>
    <div class="post-content">
      <Content />
    </div>
    <div class="post-footer">
      <a href="/blog">← 記事一覧に戻る</a>
    </div>
  </article>
</Layout>

<style>
  .post { max-width: 660px; margin: 0 auto; }

  .post-header {
    margin-bottom: 48px;
    padding-bottom: 28px;
    border-bottom: 1px solid #f0e8e4;
  }
  .post-header time {
    font-size: 0.78rem;
    color: #bbb;
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 12px;
  }
  .post-header h1 {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.9rem;
    font-weight: 600;
    line-height: 1.5;
    color: #1a1a1a;
    margin-bottom: 12px;
    letter-spacing: 0.02em;
  }
  .post-desc {
    font-size: 0.9rem;
    color: #aaa;
    line-height: 1.6;
  }

  .post-content { font-size: 1rem; line-height: 2; }
  .post-content h2 {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.2rem;
    font-weight: 600;
    margin: 44px 0 16px;
    color: #1a1a1a;
    padding-bottom: 6px;
    border-bottom: 1px solid #f0e8e4;
  }
  .post-content p { margin-bottom: 20px; color: #333; }
  .post-content blockquote {
    border-left: 3px solid #e8c4bb;
    padding: 12px 16px;
    margin: 28px 0;
    background: #fdf8f5;
    border-radius: 0 8px 8px 0;
    color: #888;
    font-size: 0.88rem;
    line-height: 1.8;
  }
  .post-content hr {
    border: none;
    border-top: 1px solid #f0e8e4;
    margin: 32px 0;
  }

  .post-footer { margin-top: 60px; padding-top: 24px; border-top: 1px solid #f0e8e4; }
  .post-footer a {
    color: #b5352a;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
  }
  .post-footer a:hover { text-decoration: underline; }
</style>

<style is:global>
  .post-content img {
    display: block;
    width: 100%;
    max-width: 520px;
    height: auto;
    border-radius: 12px;
    margin: 0 auto 28px;
  }
</style>
