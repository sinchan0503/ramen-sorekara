---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | ラーメン、それから。`} description={post.data.description}>
  <article class="post">
    <header class="post-header">
      <time>{post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      <h1>{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
    </header>
    <div class="post-content">
      <Content />
    </div>
    <div class="post-footer">
      <a href="/blog">← 記事一覧に戻る</a>
    </div>
  </article>
</Layout>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
  }

  /* ── ヘッダー ── */
  .post-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 2px solid #f0e8e4;
  }
  .post-header time {
    display: block;
    font-size: 0.8rem;
    color: #c0a090;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }
  .post-header h1 {
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(1.8rem, 4.5vw, 2.4rem);
    font-weight: 600;
    line-height: 1.5;
    color: #1a1a1a;
    margin-bottom: 16px;
    letter-spacing: 0.04em;
  }
  .post-desc {
    font-size: 1rem;
    color: #999;
    line-height: 1.8;
  }

  /* ── 本文 ── */
  .post-content {
    font-size: 1.08rem;
    line-height: 2.1;
    color: #2e2e2e;
  }

  .post-content p {
    margin-bottom: 28px;
  }

  .post-content h2 {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.3rem;
    font-weight: 600;
    margin: 60px 0 20px;
    color: #1a1a1a;
    letter-spacing: 0.04em;
    padding-left: 16px;
    border-left: 3px solid #b5352a;
    line-height: 1.6;
  }

  .post-content blockquote {
    border: none;
    padding: 24px 28px 24px 48px;
    margin: 40px 0;
    background: #fdf8f5;
    border-radius: 12px;
    color: #999;
    font-size: 0.9rem;
    line-height: 2;
    position: relative;
  }
  .post-content blockquote::before {
    content: '"';
    font-family: 'Shippori Mincho', serif;
    font-size: 4rem;
    color: #e8c4bb;
    position: absolute;
    top: 4px;
    left: 12px;
    line-height: 1;
  }

  .post-content hr {
    border: none;
    border-top: 1px solid #f0e8e4;
    margin: 40px 0;
  }

  /* ── フッター ── */
  .post-footer {
    margin-top: 72px;
    padding-top: 28px;
    border-top: 1px solid #f0e8e4;
  }
  .post-footer a {
    color: #b5352a;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .post-footer a:hover { text-decoration: underline; }
</style>

<style is:global>
  /* 記事内の画像 */
  .post-content img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    border-radius: 16px;
    margin: 4px 0 40px;
    box-shadow: 0 6px 28px rgba(0,0,0,0.10);
  }
</style>
