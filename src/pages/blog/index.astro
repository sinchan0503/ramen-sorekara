---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="記事一覧 | ラーメン、それから。">
  <h1 class="page-title">記事一覧</h1>
  <div class="post-grid">
    {posts.map(post => (
      <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-card">
        <div class="card-thumb">
          {post.data.image
            ? <img src={post.data.image} alt={post.data.title} />
            : <div class="card-emoji">{post.data.emoji}</div>
          }
        </div>
        <div class="card-body">
          <time>{post.data.pubDate.toLocaleDateString('ja-JP')}</time>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .page-title {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 32px;
    color: #2a2a2a;
    letter-spacing: 0.04em;
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }
  .post-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid #f0e8e4;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.07);
  }
  .card-thumb {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #fdf0ed;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card-emoji { font-size: 3rem; }
  .card-body { padding: 16px 20px 20px; }
  .card-body time {
    font-size: 0.75rem;
    color: #bbb;
    letter-spacing: 0.03em;
  }
  .card-body h2 {
    font-family: 'Shippori Mincho', serif;
    font-size: 1.05rem;
    font-weight: 600;
    margin: 6px 0 8px;
    color: #2a2a2a;
    line-height: 1.5;
  }
  .card-body p {
    font-size: 0.82rem;
    color: #999;
    line-height: 1.6;
  }
</style>
